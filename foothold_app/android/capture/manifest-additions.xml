<!--
  Merge into foothold_app/android/app/src/main/AndroidManifest.xml.
  (permissions inside <manifest>; components inside <application>.)
  Package: dev.rohit.foothold.capture
-->

<!-- ===== permissions (inside <manifest>) ===== -->
<uses-permission android:name="android.permission.READ_CALL_LOG"/>
<uses-permission android:name="android.permission.READ_PHONE_STATE"/>
<uses-permission android:name="android.permission.READ_CONTACTS"/>
<uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
<uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
<uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE"/>
<uses-permission android:name="android.permission.INTERNET"/>

<!-- ===== components (inside <application>) ===== -->

<!-- one-time setup screen -->
<activity
    android:name="dev.rohit.foothold.capture.CaptureSetupActivity"
    android:exported="true"
    android:label="Foothold Capture Setup"/>

<!-- foreground service: watches the call log for tagged leads -->
<service
    android:name="dev.rohit.foothold.capture.CallCaptureService"
    android:exported="false"
    android:foregroundServiceType="specialUse">
    <property
        android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
        android:value="Captures call/message activity for the user's own sales leads"/>
</service>

<!-- WhatsApp inbound via Notification access (special grant required) -->
<service
    android:name="dev.rohit.foothold.capture.WaNotificationListener"
    android:exported="false"
    android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
    <intent-filter>
        <action android:name="android.service.notification.NotificationListenerService"/>
    </intent-filter>
</service>
