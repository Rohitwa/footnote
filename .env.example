# ── Foothold configuration — copy to .env and fill in. KEEP REAL KEYS OUT OF GIT. ──

# OpenAI (universal capture router, next-move suggestions, vision capture)
OPENAI_API_KEY=
# Optional: route OpenAI calls through a proxy
OPENAI_BASE_URL=

# Sarvam (speech-to-text for voice capture; optional)
SARVAM_API_KEY=

# Storage: "postgres" (set DATABASE_URL) or "sqlite" (set FOOTHOLD_DB_PATH)
FOOTHOLD_DB=sqlite
FOOTHOLD_DB_PATH=./foothold.db
DATABASE_URL=
FOOTHOLD_PG_SCHEMA=public

# Server
FOOTHOLD_PORT=8300
# When research runs inline ("inline") vs is queued for a worker ("queue")
FOOTHOLD_RESEARCH_MODE=inline
# Shared-secret auth gate (only enforced when FLY_APP_NAME is set / on Fly)
FOOTHOLD_TOKEN=
